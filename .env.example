# Environment Variables for Law Agent
#
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
#
# These variables override values in config.yaml
# All secrets should be set here, never in config.yaml

# ============================================================================
# DATABASE CREDENTIALS
# ============================================================================
# Required: PostgreSQL database password
# Keep this secret! Never commit .env to git.
DB_PASSWORD=your-database-password-here

# ============================================================================
# LLM API CREDENTIALS
# ============================================================================
# Required: Anthropic API key for Claude access
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL: LOGGING AND OBSERVABILITY
# ============================================================================
# Enable structured JSON logging (for Arize Phoenix integration)
# LOGGING_FORMAT=json

# Set log file path if you want file output in addition to console
# LOGGING_FILE_PATH=/var/log/law-agent.log
