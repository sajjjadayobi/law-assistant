# Environment Variables for Law Agent
#
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
#
# These variables override values in config.yaml
# All secrets should be set here, never in config.yaml

# ============================================================================
# LLM API CONFIGURATION
# ============================================================================
# Custom LLM endpoint (e.g., LiteLLM proxy, custom Anthropic gateway)
# This is the base URL for your LLM provider
# Example: https://litellm.yourcompany.com
# If not set, defaults to Anthropic's API (https://api.anthropic.com)
LLM_BASE_URL=https://litellm.data.yourcompany.com

# Authentication token for the LLM endpoint
# For Anthropic direct: get from https://console.anthropic.com/account/keys
# For custom providers: get from your LLM provider
# Format: usually starts with sk- for Anthropic, other prefixes for other providers
LLM_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# CHAINLIT UI CONFIGURATION
# ============================================================================
# Required: Secret key for Chainlit authentication
# Used to sign JWT tokens for session management
# Generate a random string: `openssl rand -base64 32` or `python -c "import secrets; print(secrets.token_urlsafe(32))"`
CHAINLIT_AUTH_SECRET=your-random-secret-key-here

# ============================================================================
# DATABASE CREDENTIALS (Optional)
# ============================================================================
# PostgreSQL password for database connection
# If not set, uses DB_PASSWORD from environment or config.yaml default
# DB_PASSWORD=your-database-password-here

# ============================================================================
# OBSERVABILITY (Optional)
# ============================================================================
# Phoenix observability backend endpoint
# Default: http://localhost:6006 (self-hosted)
# For production: set to your Phoenix deployment
# PHOENIX_ENDPOINT=http://localhost:6006

# ============================================================================
# LOGGING (Optional)
# ============================================================================
# Log format for structured logging
# json = machine-parseable (production, integrates with observability)
# text = human-readable (development)
# LOGGING_FORMAT=json

# Log file path for file output
# If not set, logs only to console/stderr (recommended for Docker)
# Example: /var/log/law-agent.log
# LOGGING_FILE_PATH=/var/log/law-agent.log

# ============================================================================
# OPENTELEMETRY (Optional)
# ============================================================================
# OTLP exporter endpoint for OpenTelemetry spans
# Default: http://localhost:4317
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name for observability
# OTEL_SERVICE_NAME=law-agent

# Service version for observability
# OTEL_SERVICE_VERSION=0.0.2

# Environment name (development, staging, production)
# ENVIRONMENT=development
