# Environment Variables for Law Agent
#
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control!

# ============================================================================
# LLM API CONFIGURATION
# ============================================================================
# Base URL for the LLM provider (OpenAI-compatible endpoint)
# Example: https://api.metisai.ir/openai/v1
LLM_BASE_URL="https://api.metisai.ir/openai/v1"

# Authentication token for the LLM endpoint
# Get this from your LLM provider dashboard
LLM_AUTH_TOKEN="tpsg-xxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# CHAINLIT UI CONFIGURATION
# ============================================================================
# Required: secret key used to sign JWT session tokens
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
CHAINLIT_AUTH_SECRET="your-random-secret-key-here"

# Invite code for login (optional)
# Users must enter this as the "password" field to authenticate.
# Leave empty or unset to accept any password (development only).
INVITE_CODE="your-invite-code-here"

# ============================================================================
# DATABASE CREDENTIALS (Optional — defaults match docker-compose.yml)
# ============================================================================
# DB_PASSWORD=your-database-password-here

# ============================================================================
# OBSERVABILITY (Optional)
# ============================================================================
# Phoenix endpoint (default: http://localhost:6006 for local, http://phoenix:6006 in Docker)
# PHOENIX_ENDPOINT=http://localhost:6006

# OTLP exporter endpoint for OpenTelemetry spans (default: http://localhost:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ============================================================================
# LOGGING (Optional)
# ============================================================================
# json = machine-readable (production) | text = human-readable (development)
# LOGGING_FORMAT=json
